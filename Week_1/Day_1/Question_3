class Solution {
    public int maxProfit(int[] prices) {
     int max_profit=0;
     int best_buy=prices[0];
     for(int i=1;i<prices.length;i++)
     {
        best_buy=(best_buy>prices[i])? prices[i]:best_buy;
        
        max_profit=(max_profit>(prices[i]-best_buy))?max_profit:prices[i]-best_buy;
     }   
     return max_profit;
    }
}
