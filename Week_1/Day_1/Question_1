class Solution {
public int[] twoSum(int[] nums, int target)
{
    int r=0,x=0;
    HashMap <Integer,Integer> map= new HashMap<>();
    for(int i=0;i<nums.length;i++)
    {
        r=target-nums[i];
        if(map.containsKey(r))
        {
            x=map.get(r);
            return new int[]{x,i};
        }
        else
        map.put(nums[i],i);
    }
    return new int[]{-1,-1};
}
    
    
}
