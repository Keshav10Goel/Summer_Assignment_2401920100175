class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int s=0;
        double avg=Double.MIN_VALUE;
        for(int i=0;i<k;i++)
        s+=nums[i];
        int l=0;
        int max_s=s;
        for(int i=k;i<nums.length;i++)
        {
            s+=nums[i];
            s-=nums[i-k];
            max_s=(max_s>s)?max_s:s;
        }
        avg=max_s/(double)k;
        return avg;
    }
    
}
